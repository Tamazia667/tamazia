# Example environment variables (DO NOT COMMIT SECRETS)
# Use GitHub repository secrets for CI (Settings → Settings → Secrets and variables → Actions).

# GitHub token for local gh usage (do NOT commit real tokens)
# For CI, rely on the built-in GITHUB_TOKEN provided by GitHub Actions.
# GITHUB_TOKEN=ghp_xxx   # <-- never commit

# If you publish to npm from CI you may need an NPM token (store in repo secret NPM_TOKEN)
# NPM_TOKEN=your-npm-token

# Optional: private GitHub token with repo scope for local usage (avoid committing)
# PRIVATE_GH_TOKEN=ghp_xxx

# Notes:
# - Never commit real tokens. Use GitHub Secrets for actions and local gh auth for local pushes/releases.
# - The workflows in .github/workflows use ${{ secrets.GITHUB_TOKEN }} provided by GitHub Actions to create releases.

NODE_ENV=production
